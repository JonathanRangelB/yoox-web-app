{
  "name": "yoox-web-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "env": "node ./scripts/set-env.js",
    "start": "pnpm run env && ng serve --configuration development",
    "build": "pnpm run env && ng build --configuration production",
    "build:purgecss": "pnpm run env && ng build --configuration production",
    "watch": "pnpm run env && ng build --watch --configuration development",
    "test": "pnpm run env && ng test --configuration development",
    "commitlint": "commitlint --edit",
    "husky:init": "npx husky-init && rm .husky/pre-commit && chmod ug+x .husky/*",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "lint:ci": "ng lint --fix",
    "test:ci": "ng test --browsers ChromeHeadless --watch false",
    "e2e:ci": "ng e2e --watch false --headless",
    "all:ci": "pnpm run env && npm run lint:ci && npm run test:ci && npm run e2e:ci",
    "prepare": "husky install",
    "postbuild": "node ./scripts/purgecss.mjs",
    "httpserver": "pnpm dlx http-server dist/yoox-web-app/browser/ -p 4200"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.1.1",
    "@angular/cdk": "^21.1.1",
    "@angular/common": "^21.1.1",
    "@angular/compiler": "^21.1.1",
    "@angular/core": "^21.1.1",
    "@angular/forms": "^21.1.1",
    "@angular/platform-browser": "^21.1.1",
    "@angular/platform-browser-dynamic": "^21.1.1",
    "@angular/router": "^21.1.1",
    "@typescript-eslint/types": "^8.53.1",
    "@typescript-eslint/utils": "^8.53.1",
    "jwt-decode": "^4.0.0",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primeng": "^17.18.15",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "21.1.0",
    "@angular-eslint/eslint-plugin": "21.1.0",
    "@angular-eslint/eslint-plugin-template": "21.1.0",
    "@angular-eslint/schematics": "21.1.0",
    "@angular-eslint/template-parser": "21.1.0",
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.1",
    "@angular/language-service": "^21.1.1",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@cypress/schematic": "^3.0.0",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@schematics/angular": "^19.2.19",
    "@types/jasmine": "~5.1.15",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "autoprefixer": "^10.4.23",
    "cypress": "^14.5.4",
    "dotenv": "^16.6.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "purgecss": "^7.0.2",
    "typescript": "~5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "cypress",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}
